# SurpriseSage — API keys for cloud LLM providers
# Copy this file to .env and fill in the keys you need.
# Only the key for your chosen provider is required.

# Grok (x.ai)
# XAI_API_KEY=xai-...

# Claude (Anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# ChatGPT (OpenAI)
# OPENAI_API_KEY=sk-...

# Gemini (Google)
# GEMINI_API_KEY=...
